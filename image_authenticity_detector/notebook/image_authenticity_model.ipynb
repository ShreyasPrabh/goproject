# Save the model and create prediction function
def predict_image(image_path):
    """Predict if an image is real/fake and if real, whether it's edited"""
    # Load and preprocess image
    img = load_and_preprocess_image(image_path)
    if img is None:
        return None, None, "Error loading image"
    
    # Expand dimensions for batch prediction
    img_batch = np.expand_dims(img, axis=0)
    
    # Make prediction
    predictions = model.predict(img_batch, verbose=0)
    real_fake_prob = predictions[0][0][0]
    edited_prob = predictions[1][0][0]
    
    # Determine results
    is_real = real_fake_prob > 0.5
    is_edited = edited_prob > 0.5
    
    # Format results
    if is_real:
        authenticity = f"Real (confidence: {real_fake_prob:.3f})"
        if is_edited:
            edit_status = f"Edited (confidence: {edited_prob:.3f})"
        else:
            edit_status = f"Unedited (confidence: {1-edited_prob:.3f})"
    else:
        authenticity = f"AI-Generated/Fake (confidence: {1-real_fake_prob:.3f})"
        edit_status = "N/A (Only applicable to real images)"
    
    return authenticity, edit_status, "Success"

