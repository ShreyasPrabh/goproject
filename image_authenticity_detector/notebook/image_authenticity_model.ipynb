def load_dataset():
    """Load and prepare the dataset"""
    images = []
    real_fake_labels = []  # 0: fake, 1: real
    edited_labels = []     # 0: unedited, 1: edited (only for real images)
    
    # Load fake images
    fake_files = [f for f in os.listdir(FAKE_PATH) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
    for filename in fake_files:
        img_path = os.path.join(FAKE_PATH, filename)
        img = load_and_preprocess_image(img_path)
        if img is not None:
            images.append(img)
            real_fake_labels.append(0)  # fake
            edited_labels.append(-1)    # not applicable for fake images
    
    # Load real unedited images
    real_unedited_files = [f for f in os.listdir(REAL_UNEDITED_PATH) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
    for filename in real_unedited_files:
        img_path = os.path.join(REAL_UNEDITED_PATH, filename)
        img = load_and_preprocess_image(img_path)
        if img is not None:
            images.append(img)
            real_fake_labels.append(1)  # real
            edited_labels.append(0)     # unedited
    
    # Load real edited images
    real_edited_files = [f for f in os.listdir(REAL_EDITED_PATH) if f.lower().endswith(('.png', '.jpg', '.jpeg'))]
    for filename in real_edited_files:
        img_path = os.path.join(REAL_EDITED_PATH, filename)
        img = load_and_preprocess_image(img_path)
        if img is not None:
            images.append(img)
            real_fake_labels.append(1)  # real
            edited_labels.append(1)     # edited
    
    images = np.array(images)
    real_fake_labels = np.array(real_fake_labels)
    edited_labels = np.array(edited_labels)
    
    print(f"Dataset loaded: {len(images)} images")
    print(f"Fake images: {sum(real_fake_labels == 0)}")
    print(f"Real unedited images: {sum((real_fake_labels == 1) & (edited_labels == 0))}")
    print(f"Real edited images: {sum((real_fake_labels == 1) & (edited_labels == 1))}")
    
    return images, real_fake_labels, edited_labels

# Load the dataset
X, y_real_fake, y_edited = load_dataset()# Data loading and preprocessing functions
def load_and_preprocess_image(image_path):
    """Load and preprocess image for training"""
    try:
        image = cv2.imread(image_path)
        if image is None:
            return None
        image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
        image = cv2.resize(image, IMG_SIZE)
        image = image.astype(np.float32) / 255.0
        return image
    except Exception as e:
        print(f"Error loading image {image_path}: {e}")
        return None

