def create_model():
    """Create a multi-output CNN model for image authenticity detection"""
    
    # Input layer
    input_layer = layers.Input(shape=(IMG_SIZE[0], IMG_SIZE[1], 3))
    
    # Shared feature extraction layers
    x = layers.Conv2D(32, (3, 3), activation='relu', padding='same')(input_layer)
    x = layers.BatchNormalization()(x)
    x = layers.MaxPooling2D((2, 2))(x)
    
    x = layers.Conv2D(64, (3, 3), activation='relu', padding='same')(x)
    x = layers.BatchNormalization()(x)
    x = layers.MaxPooling2D((2, 2))(x)
    
    x = layers.Conv2D(128, (3, 3), activation='relu', padding='same')(x)
    x = layers.BatchNormalization()(x)
    x = layers.MaxPooling2D((2, 2))(x)
    
    x = layers.Conv2D(256, (3, 3), activation='relu', padding='same')(x)
    x = layers.BatchNormalization()(x)
    x = layers.MaxPooling2D((2, 2))(x)
    
    x = layers.Conv2D(512, (3, 3), activation='relu', padding='same')(x)
    x = layers.BatchNormalization()(x)
    x = layers.GlobalAveragePooling2D()(x)
    
    # Shared dense layers
    shared_dense = layers.Dense(512, activation='relu')(x)
    shared_dense = layers.Dropout(0.5)(shared_dense)
    shared_dense = layers.Dense(256, activation='relu')(shared_dense)
    shared_dense = layers.Dropout(0.3)(shared_dense)
    
    # Output 1: Real vs Fake classification
    real_fake_branch = layers.Dense(128, activation='relu', name='real_fake_dense')(shared_dense)
    real_fake_branch = layers.Dropout(0.3)(real_fake_branch)
    real_fake_output = layers.Dense(1, activation='sigmoid', name='real_fake_output')(real_fake_branch)
    
    # Output 2: Edited vs Unedited classification (for real images)
    edited_branch = layers.Dense(128, activation='relu', name='edited_dense')(shared_dense)
    edited_branch = layers.Dropout(0.3)(edited_branch)
    edited_output = layers.Dense(1, activation='sigmoid', name='edited_output')(edited_branch)
    
    # Create the model
    model = models.Model(
        inputs=input_layer,
        outputs=[real_fake_output, edited_output],
        name='ImageAuthenticityDetector'
    )
    
    return model

# Create and compile the model
model = create_model()

# Custom loss function to handle the multi-output nature
def custom_loss(y_true, y_pred):
    """Custom loss function for multi-output model"""
    real_fake_true, edited_true = y_true[:, 0], y_true[:, 1]
    real_fake_pred, edited_pred = y_pred[0], y_pred[1]
    
    # Real/Fake loss (always computed)
    real_fake_loss = tf.keras.losses.binary_crossentropy(real_fake_true, real_fake_pred)
    
    # Edited loss (only for real images)
    real_mask = tf.cast(real_fake_true == 1, tf.float32)
    edited_loss = tf.keras.losses.binary_crossentropy(edited_true, edited_pred) * real_mask
    
    return real_fake_loss + edited_loss

# Compile the model
model.compile(
    optimizer=tf.keras.optimizers.Adam(learning_rate=LEARNING_RATE),
    loss={
        'real_fake_output': 'binary_crossentropy',
        'edited_output': 'binary_crossentropy'
    },
    loss_weights={
        'real_fake_output': 1.0,
        'edited_output': 0.5  # Lower weight for edited classification
    },
    metrics=['accuracy']
)

